generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/nexxos_mvp/nodejs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  password     String
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  name         String
  phone        String
  documentId   String   @unique @map("document_id")
  profileImageUrl String?  @map("profile_image_url")
  isActive     Boolean  @default(true) @map("is_active")
  emailVerified Boolean @default(false) @map("email_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userRoles           UserRole[]
  vendor              Vendor?
  clientRequests      Request[]
  chatMessages        ChatMessage[]
  requestRatingsGiven RequestRating[] @relation("RatingClient")
  chatsAsClient       Chat[]          @relation("ChatClient")
  files               File[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  pushTokens          PushToken[]

  @@map("users")
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   // 'android' | 'ios'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Vendor {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  businessName            String   @map("business_name")
  rif                     String
  logoUrl                 String?  @map("logo_url")
  documentImageUrl        String?  @map("document_image_url")
  country                 String?
  city                    String?
  state                   String?
  municipality            String?
  parish                  String?
  street                  String?
  postalCode              String?  @map("postal_code")
  latitude                Float?
  longitude               Float?
  referencePoint          String?  @map("reference_point")
  fullAddress             String?  @map("full_address")
  isAvailable             Boolean   @default(true) @map("is_available")
  personalDocUrl          String?   @map("personal_doc_url")
  selfieUrl               String?   @map("selfie_url")
  identityVerified        Boolean   @default(false) @map("identity_verified")
  identityVerifiedAt      DateTime? @map("identity_verified_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user                    User                    @relation(fields: [userId], references: [id])
  vendorVehicleModels     VendorVehicleModel[]
  vendorPartSubcategories VendorPartSubcategory[]
  vendorMetrics           VendorMetrics?
  requestVendorMatches    RequestVendorMatch[]
  requestResponses        RequestResponse[]
  chats                   Chat[]
  requestRatingsReceived  RequestRating[]         @relation("RatingVendor")
  vendorSubscriptions     VendorSubscription[]

  @@map("vendors")
}

model VendorMetrics {
  id                    String    @id @default(uuid()) @db.Uuid
  vendorId              String    @unique @map("vendor_id") @db.Uuid
  totalRequestsReceived Int       @default(0) @map("total_requests_received")
  totalRequestsAnswered Int       @default(0) @map("total_requests_answered")
  avgRating             Float?    @map("avg_rating")
  totalRatings          Int       @default(0) @map("total_ratings")
  lastActivityAt        DateTime? @map("last_activity_at")

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_metrics")
}

model VehicleBrand {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  vehicleModels VehicleModel[]
  requests      Request[]

  @@map("vehicle_brands")
}

model VehicleModel {
  id      String @id @default(uuid()) @db.Uuid
  brandId String @map("brand_id") @db.Uuid
  name    String

  brand              VehicleBrand         @relation(fields: [brandId], references: [id])
  vendorVehicleModels VendorVehicleModel[]
  requests           Request[]

  @@unique([brandId, name])
  @@map("vehicle_models")
}

model PartCategory {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  partSubcategories PartSubcategory[]
  requests          Request[]

  @@map("part_categories")
}

model PartSubcategory {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  name       String

  category               PartCategory            @relation(fields: [categoryId], references: [id])
  vendorPartSubcategories VendorPartSubcategory[]
  requests               Request[]

  @@unique([categoryId, name])
  @@map("part_subcategories")
}

model State {
  id      String  @id @default(uuid()) @db.Uuid
  name    String  @unique
  capital String?
  isoCode String? @map("iso_code")

  municipalities Municipality[]
  requests       Request[]

  @@map("states")
}

model Municipality {
  id      String @id @default(uuid()) @db.Uuid
  stateId String @map("state_id") @db.Uuid
  name    String

  state    State     @relation(fields: [stateId], references: [id])
  requests Request[]
  parishes Parish[]

  @@unique([stateId, name])
  @@map("municipalities")
}

model Parish {
  id             String @id @default(uuid()) @db.Uuid
  municipalityId String @map("municipality_id") @db.Uuid
  name           String

  municipality Municipality @relation(fields: [municipalityId], references: [id])
  requests     Request[]

  @@unique([municipalityId, name])
  @@index([municipalityId])
  @@map("parishes")
}

model VendorVehicleModel {
  id             String @id @default(uuid()) @db.Uuid
  vendorId       String @map("vendor_id") @db.Uuid
  vehicleModelId String @map("vehicle_model_id") @db.Uuid

  vendor       Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vehicleModel VehicleModel @relation(fields: [vehicleModelId], references: [id])

  @@unique([vendorId, vehicleModelId])
  @@map("vendor_vehicle_models")
}

model VendorPartSubcategory {
  id                String @id @default(uuid()) @db.Uuid
  vendorId          String @map("vendor_id") @db.Uuid
  partSubcategoryId String @map("part_subcategory_id") @db.Uuid

  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  partSubcategory PartSubcategory @relation(fields: [partSubcategoryId], references: [id])

  @@unique([vendorId, partSubcategoryId])
  @@map("vendor_part_subcategories")
}

model Request {
  id                String    @id @default(uuid()) @db.Uuid
  clientId          String    @map("client_id") @db.Uuid
  vehicleBrandId    String    @map("vehicle_brand_id") @db.Uuid
  vehicleModelId    String    @map("vehicle_model_id") @db.Uuid
  partCategoryId    String    @map("part_category_id") @db.Uuid
  partSubcategoryId String?   @map("part_subcategory_id") @db.Uuid
  stateId           String?   @map("state_id") @db.Uuid
  municipalityId    String?   @map("municipality_id") @db.Uuid
  parishId          String?   @map("parish_id") @db.Uuid
  searchRadiusKm    Int?      @map("search_radius_km")
  latitude          Float?
  longitude         Float?
  freeDescription   String    @map("free_description")
  status            String    @default("ABIERTA")
  lastMessageAt     DateTime? @map("last_message_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  closedAt          DateTime? @map("closed_at")

  client              User                 @relation(fields: [clientId], references: [id])
  vehicleBrand        VehicleBrand         @relation(fields: [vehicleBrandId], references: [id])
  vehicleModel        VehicleModel         @relation(fields: [vehicleModelId], references: [id])
  partCategory        PartCategory         @relation(fields: [partCategoryId], references: [id])
  partSubcategory     PartSubcategory?     @relation(fields: [partSubcategoryId], references: [id])
  state               State?               @relation(fields: [stateId], references: [id])
  municipality        Municipality?        @relation(fields: [municipalityId], references: [id])
  parish              Parish?              @relation(fields: [parishId], references: [id])
  requestVendorMatches RequestVendorMatch[]
  requestResponses    RequestResponse[]
  chats               Chat[]
  requestRating       RequestRating?

  @@index([clientId])
  @@index([status])
  @@index([stateId, municipalityId])
  @@map("requests")
}

model RequestVendorMatch {
  id          String    @id @default(uuid()) @db.Uuid
  requestId   String    @map("request_id") @db.Uuid
  vendorId    String    @map("vendor_id") @db.Uuid
  deliveredAt DateTime  @default(now()) @map("delivered_at")
  responded   Boolean   @default(false)
  declined    Boolean   @default(false)
  respondedAt DateTime? @map("responded_at")
  declinedAt  DateTime? @map("declined_at")

  request Request @relation(fields: [requestId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([requestId, vendorId])
  @@index([vendorId])
  @@index([requestId])
  @@map("request_vendor_matches")
}

model RequestResponse {
  id             String   @id @default(uuid()) @db.Uuid
  requestId      String   @map("request_id") @db.Uuid
  vendorId       String   @map("vendor_id") @db.Uuid
  initialMessage String   @map("initial_message")
  createdAt      DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([requestId, vendorId])
  @@map("request_responses")
}

model Chat {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @map("request_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  request      Request       @relation(fields: [requestId], references: [id])
  vendor       Vendor        @relation(fields: [vendorId], references: [id])
  client       User          @relation("ChatClient", fields: [clientId], references: [id])
  chatMessages ChatMessage[]

  @@unique([requestId, vendorId, clientId])
  @@index([clientId])
  @@index([vendorId])
  @@map("chats")
}

model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  chatId        String   @map("chat_id") @db.Uuid
  senderId      String   @map("sender_id") @db.Uuid
  messageText   String   @map("message_text")
  messageType   String   @default("text") @map("message_type")
  imageUrl      String?  @map("image_url")
  replyToId     String?  @map("reply_to_id") @db.Uuid
  status        String   @default("sent") @map("status") // sent | delivered | read
  isEdited      Boolean  @default(false) @map("is_edited")
  deletedForAll Boolean  @default(false) @map("deleted_for_all")
  createdAt     DateTime @default(now()) @map("created_at")

  chat    Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User         @relation(fields: [senderId], references: [id])
  replyTo ChatMessage? @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies ChatMessage[] @relation("MessageReply")

  @@index([chatId, createdAt])
  @@map("chat_messages")
}

model RequestRating {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @unique @map("request_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id])
  client  User    @relation("RatingClient", fields: [clientId], references: [id])
  vendor  Vendor  @relation("RatingVendor", fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("request_ratings")
}

model File {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  fileName           String   @map("file_name")
  cloudStoragePath   String   @map("cloud_storage_path")
  isPublic           Boolean  @default(false) @map("is_public")
  contentType        String   @map("content_type")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("files")
}

model Plan {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  price        Float
  billingCycle String  @map("billing_cycle")
  isActive     Boolean @default(true) @map("is_active")

  vendorSubscriptions VendorSubscription[]

  @@map("plans")
}

model VendorSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status    String

  vendor Vendor @relation(fields: [vendorId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("vendor_subscriptions")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, code])
  @@map("email_verification_codes")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
